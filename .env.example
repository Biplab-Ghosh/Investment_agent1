# External API key folder (optional; defaults to E:\PyCharm Projects\APIs)
# EXTERNAL_APIS_DIR=E:\PyCharm Projects\APIs

# ── LLM Providers ──────────────────────────────────────────────────
# Primary model (GPT-4o mini, cost-effective)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic Claude as alternative
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Financial Data APIs ────────────────────────────────────────────
# Alpha Vantage – free tier: 500 calls/day
# Register at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# FRED (Federal Reserve Economic Data) – free, no limit
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ── Model Settings ─────────────────────────────────────────────────
DEFAULT_LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
MAX_TOKENS=4096

# ── Cache Settings ─────────────────────────────────────────────────
CACHE_DIR=data/cache
DB_PATH=data/cache/investment_cache.db
MARKET_DATA_TTL_HOURS=24
FUNDAMENTAL_DATA_TTL_DAYS=90

# ── Analysis Defaults ──────────────────────────────────────────────
MARKET_RISK_PREMIUM=0.07
DEFAULT_TAX_RATE=0.21
DCF_FORECAST_YEARS=5
MONTE_CARLO_SIMULATIONS=10000
